{
	"name": "web",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm run build:packages && vp exec vite dev",
		"build": "pnpm run build:packages && vp exec vite build",
		"preview": "vp exec vite preview",
		"prepare": "vp exec svelte-kit sync || echo ''",
		"check": "vp exec svelte-kit sync && vp exec svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "vp exec svelte-kit sync && vp exec svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "pnpm -w format",
		"lint": "pnpm -w lint",
		"test:unit": "vp exec vitest",
		"test": "pnpm run test:unit -- --run && pnpm run test:e2e",
		"test:e2e": "vp exec playwright install && vp exec playwright test",
		"coverage": "vp exec vitest run --coverage",
		"build:packages": "pnpm -r --filter=\"../../packages/*\" run build"
	},
	"devDependencies": {
		"@playwright/test": "catalog:",
		"@sveltejs/adapter-auto": "^6.1.0",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"@vitest/browser": "catalog:",
		"@vitest/browser-playwright": "^4.1.7",
		"@vitest/coverage-v8": "catalog:",
		"daisyui": "^5.5.8",
		"fathom-client": "^3.7.2",
		"globals": "^16.5.0",
		"mdsvex": "^0.12.6",
		"playwright": "^1.57.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-external-links": "^3.0.0",
		"rehype-slug": "^6.0.0",
		"svead": "workspace:*",
		"svelte": "^5.55.9",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.1.17",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:",
		"vitest-browser-svelte": "^2.1.1"
	}
}
