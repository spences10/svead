{
	"name": "svead",
	"version": "0.0.15",
	"keywords": [
		"facebook",
		"head",
		"json-ld",
		"jsonld",
		"meta-tags",
		"og",
		"open-graph",
		"schema",
		"seo",
		"social",
		"structured-data",
		"svelte",
		"sveltekit",
		"twitter"
	],
	"homepage": "https://github.com/spences10/svead#readme",
	"bugs": {
		"url": "https://github.com/spences10/svead/issues"
	},
	"license": "MIT",
	"author": {
		"name": "Scott Spence",
		"email": "svead@scottspence.dev",
		"url": "https://scottspence.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spences10/svead.git"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"type": "module",
	"types": "./dist/index.d.ts",
	"svelte": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"scripts": {
		"dev": "vp exec vite dev",
		"build": "vp exec vite build && pnpm run package",
		"preview": "vp exec vite preview",
		"package": "pnpm run package:readme && vp exec svelte-kit sync && vp exec svelte-package && vp exec publint",
		"package:readme": "cp ../../README.md README.md",
		"prepublishOnly": "pnpm run package",
		"test": "pnpm run test:integration && pnpm run test:unit -- --run",
		"check": "vp exec svelte-kit sync && vp exec svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "vp exec svelte-kit sync && vp exec svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "pnpm -w lint",
		"format": "pnpm -w format",
		"test:integration": "vp exec playwright test",
		"test:unit": "vp exec vitest",
		"test:ci": "vp exec vitest run",
		"coverage": "vp exec vitest run --coverage"
	},
	"dependencies": {
		"schema-dts": "^2.0.0"
	},
	"devDependencies": {
		"@playwright/test": "catalog:",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.61.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@testing-library/svelte": "^5.3.1",
		"@vitest/coverage-v8": "catalog:",
		"jsdom": "^29.1.1",
		"publint": "^0.3.21",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"tslib": "^2.8.1",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"svelte": "^4.0.0 || ^5.0.0"
	}
}
